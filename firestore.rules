rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catalog + bot charts: public read so guests can browse; writes need a signed-in user.
    // Declared as a full path (not only nested under admins/{adminId}) so list/get cannot be blocked
    // by stricter parent rules in the console or by evaluation order.
    match /admins/{adminId}/products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      match /performance_data/{docId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null;
      }
    }

    match /admins/{adminId} {
      allow read, write: if request.auth != null;

      match /users/{userId} {
        allow read, write: if request.auth != null;
        match /orders/{orderId} {
          allow read, write: if request.auth != null;
          match /licenses/{licenseId} {
            allow read, write: if request.auth != null;
          }
        }
      }

      match /orders/{orderId} {
        allow read, write: if request.auth != null;
      }
      match /licenses/{licenseId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
