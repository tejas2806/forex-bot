# Get your free API key at https://twelvedata.com/pricing
# Used for live forex/crypto time series in the admin backtest chart.
VITE_TWELVEDATA_API_KEY=67957524d30c495a8826d4a40cceb2f3

# Firebase – create a project at https://console.firebase.google.com and enable Authentication > Email/Password
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Payment / license backend (Firebase Functions API base URL)
# Set to your deployed functions URL, e.g. https://us-central1-your-project-id.cloudfunctions.net/api
VITE_PAYMENT_API_URL=

# Razorpay public test/live key (frontend). Secret key must stay in functions env only.
VITE_RAZORPAY_KEY_ID=
